<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="25dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="26sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bluetooth"
        android:textSize="18sp"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/bluetoothStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking Bluetooth..."
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/toggleBluetoothBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Bluetooth"
        android:layout_marginTop="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data Sync"
        android:textSize="18sp"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/syncStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking connection..."
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/lastSyncText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Never synced"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/syncNowBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sync Now"
        android:layout_marginTop="10dp"/>

</LinearLayout>
